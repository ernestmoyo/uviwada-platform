# Supabase — paste these from https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Server-side only — never exposed to the browser. Used by route handlers / seed script.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Server-side only — never exposed to the browser or the mobile app.
# Powers the AI curriculum / lesson-plan + assessment-recommendation features.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (default claude-opus-4-8). Cheaper: claude-sonnet-4-6 / claude-haiku-4-5
# ANTHROPIC_MODEL=claude-opus-4-8
# Shared device token the field app sends; also gates the field-facing AI endpoints
# FIELD_SYNC_TOKEN=...

# Optional: branding / contact
NEXT_PUBLIC_SITE_URL=https://uviwada-platform.vercel.app
